FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    pkg-config \
    python3-dev \
    python3-pip \
    libopencv-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . /app/radxa_cm5

RUN cd /app/radxa_cm5 && chmod +x scripts/build_rk3588.sh && ./scripts/build_rk3588.sh

CMD ["/app/radxa_cm5/build/rk3588_cow_bcs"]
