   "source": [
    "# 🔌 Google Colab Local Bridge: Connect Free T4 GPU to Local VS Code & CLI\n",
    "Run this notebook in Google Colab to start an **SSH server** and **Cloudflare Tunnel**.\n",
    "This allows your local VS Code terminal to execute commands directly on Google Colab's Free Tesla T4 GPU!"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 1: Install SSH Server and Cloudflare Tunnel\n",
    "!apt-get update && apt-get install -y openssh-server\n",
    "!mkdir -p /var/run/sshd\n",
    "!echo 'root:colab123' | chpasswd\n",
    "!sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config\n",
    "\n",
    "!wget -q https://github.com/cloudflare/cloudflare-tunnel-user-building-guide/releases/download/v2026.1.0/cloudflared-linux-amd64 -O /usr/local/bin/cloudflared\n",
    "!chmod +x /usr/local/bin/cloudflared"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 2: Start SSH Server & Cloudflare Tunnel\n",
    "import subprocess\n",
    "\n",
    "subprocess.Popen([\"/usr/sbin/sshd\", \"-D\"])\n",
    "tunnel_proc = subprocess.Popen([\"cloudflared\", \"tunnel\", \"--url\", \"ssh://localhost:22\"], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n",
    "\n",
    "print(\"Waiting for Cloudflare SSH Host URL...\")
    "for line in iter(tunnel_proc.stderr.readline, \"\"):\n",
    "    if \"trycloudflare.com\" in line:\n",
    "        print(\"\\n=================================================\")\n",
    "        print(\" 🔥 CONNECT FROM LOCAL VS CODE / TERMINAL:\")\n",
    "        print(\" \" + line.strip())\n",
    "        print(\" Password: colab123\")\n",
    "        print(\"=================================================\\n\")\n",
    "        break"
   ]
  }
