digraph ZeroCopy {
    rankdir=TB;
    bgcolor="white";
    node [shape=none, margin=0];
    edge [style=invis];

    NVIDIA [label=<
    <table border="1" color="#cccccc" cellborder="0" cellspacing="15" cellpadding="10" bgcolor="white">
        <tr><td colspan="3"><font point-size="14" face="Arial">NVIDIA Jetson Orin</font></td></tr>
        <tr>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">NVDEC Decoder</font></td>
            <td><font face="Arial" color="#666666" point-size="10">───── NVMM Buffer ─────▶</font></td>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">TensorRT Engine</font></td>
        </tr>
    </table>
    >];

    QUALCOMM [label=<
    <table border="1" color="#cccccc" cellborder="0" cellspacing="15" cellpadding="10" bgcolor="white">
        <tr><td colspan="3"><font point-size="14" face="Arial">Qualcomm RB3 Gen2</font></td></tr>
        <tr>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">Adreno GPU</font></td>
            <td><font face="Arial" color="#666666" point-size="10">── DMA-BUF / ION FD ──▶</font></td>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">Hexagon DSP</font></td>
        </tr>
    </table>
    >];

    RADXA [label=<
    <table border="1" color="#cccccc" cellborder="0" cellspacing="15" cellpadding="10" bgcolor="white">
        <tr><td colspan="5"><font point-size="14" face="Arial">Radxa CM5 RK3588</font></td></tr>
        <tr>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">MPP Decoder</font></td>
            <td><font face="Arial" color="#666666" point-size="10">── dma_buf ──▶</font></td>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">RGA Resizer</font></td>
            <td><font face="Arial" color="#666666" point-size="10">── dma_buf ──▶</font></td>
            <td bgcolor="#f5f5f5" border="1" color="#333333"><font face="Arial">RKNN NPU</font></td>
        </tr>
    </table>
    >];

    NVIDIA -> QUALCOMM;
    QUALCOMM -> RADXA;
}
