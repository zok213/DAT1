digraph ZeroCopy {
    rankdir=LR;
    node [shape=box, style=filled, color="#333333", fillcolor="#f5f5f5", fontcolor="#000000", fontname="Arial", margin=0.3];
    edge [color="#666666", fontcolor="#444444", fontname="Arial", fontsize=10];
    bgcolor="white";
    
    subgraph cluster_nvidia {
        label="NVIDIA Jetson Orin";
        fontcolor="#000000";
        fontname="Arial";
        fontsize=14;
        color="#cccccc";
        margin=20;
        NV [label="NVDEC Decoder"];
        TRT [label="TensorRT Engine"];
        NV -> TRT [label="NVMM Buffer"];
    }

    subgraph cluster_qualcomm {
        label="Qualcomm RB3 Gen2";
        fontcolor="#000000";
        fontname="Arial";
        fontsize=14;
        color="#cccccc";
        margin=20;
        ADRENO [label="Adreno GPU"];
        HEX [label="Hexagon DSP"];
        ADRENO -> HEX [label="DMA-BUF / ION FD"];
    }

    subgraph cluster_radxa {
        label="Radxa CM5 RK3588";
        fontcolor="#000000";
        fontname="Arial";
        fontsize=14;
        color="#cccccc";
        margin=20;
        MPP [label="MPP Decoder"];
        RGA [label="RGA Resizer"];
        RKNN [label="RKNN NPU"];
        MPP -> RGA [label="dma_buf"];
        RGA -> RKNN [label="dma_buf"];
    }
    
    # Force vertical stacking
    NV -> ADRENO [style=invis];
    ADRENO -> MPP [style=invis];
}
